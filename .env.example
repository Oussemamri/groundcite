# GroundCite configuration (spec §11). Copy to `.env` and fill secrets.
# This file is the single source of environment; config.py mirrors it exactly.
# `.env` is git-ignored — never commit real keys.

# --- Storage: Postgres 16 + pgvector (matches docker-compose.yml) ---
# SQLAlchemy + psycopg3 driver URL. Host port 5433 (see docker-compose.yml) avoids
# clashing with a locally-installed Postgres on 5432.
DATABASE_URL=postgresql+psycopg://groundcite:groundcite@localhost:5433/groundcite

# --- Providers (all swappable via ports, spec §11) ---
EMBEDDING_PROVIDER=bge_m3        # bge_m3 | openai
LLM_PROVIDER=groq                # groq | openai | ollama
RERANKER_ENABLED=true
EMBEDDING_MODEL=BAAI/bge-m3      # local bge-m3 model id (spec §17 rule 9)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3   # cross-encoder, normalized scores (spec §11)
SKIP_EMBEDDINGS=false            # dry-run: zero-vector embeddings (no model load)

# --- Provider credentials / endpoints ---
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- LLM generation models (AD-1; names live ONLY here, spec §17 rule 9) ---
# Groq default verified present in the live catalog on 2026-07-15 (17 models).
GROQ_MODEL=llama-3.3-70b-versatile
# Written but NOT exercised this week (only Groq is configured); names unverified.
OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=llama3.1
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Judge (evals only, AD-7) — SKIPPED this week (only Groq; judge != answerer).
# Leave unset → `eval run --judge` is a no-op (judge columns stay NULL).
JUDGE_PROVIDER=
JUDGE_MODEL=

# --- Per-call cost map (spec §12, AD-6); JSON. Empty/unset → cost_usd is NULL.
# MODEL_PRICES={"llama-3.3-70b-versatile":{"prompt":0.59,"completion":0.79}}

# --- Retrieval tunables (defaults from spec §7; tune with evals, not code) ---
TAU_RETRIEVAL=0.70               # abstain below this normalized reranker score (Gate A REQUIRES the
                                  # reranker — Week 2 proved RRF alone cannot separate grounded from
                                  # must-abstain; tuned from spec's 0.35 in Week 3 Phase 6, real
                                  # baseline: 0.35 leaked 25% of must-abstain cases through Gate A on
                                  # raw score alone. See docs/WEEK3_RESULTS.md.
RRF_K=60                         # RRF constant: score = sum 1 / (RRF_K + rank_i)
CANDIDATES_DENSE=30              # top-N dense (HNSW cosine) candidates
CANDIDATES_LEXICAL=30            # top-N lexical (ts_rank_cd) candidates
FUSED_K=20                       # keep top-N after RRF fusion
CONTEXT_K=6                      # chunks sent to the generator

# --- Ingestion tunables (spec §6 step 3) ---
MIN_LEAF_TOKENS=64               # leaf clauses below this token count merge up to parent
